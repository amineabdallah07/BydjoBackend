# ============================================================
# BY DJO Backend — Required Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# Database (Bug #11 fix — no hardcoded password)
DB_URL=jdbc:postgresql://localhost:5432/bydjo_db
DB_USERNAME=postgres
DB_PASSWORD=midou@123

# JWT (Bug #12 fix — no hardcoded fallback secret)
# Generate with: openssl rand -base64 64
JWT_SECRET=mysupersecretkeymysupersecretkeymysupersecretkey123

# Twilio SMS
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_ENABLED=false

# Mail
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Upload directory
UPLOAD_DIR=./uploads
